# NeuroInsight Research Configuration
# Copy this file to .env and adjust values as needed.

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# API Server
# Production: backend serves SPA on port 3000 (range 3000-3050)
# Development: frontend 3000 (range 3000-3050), backend 3051 (range 3051-3100)
API_HOST=0.0.0.0
API_PORT=3000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3051,http://localhost:5173

# --- Database (PostgreSQL) ---
POSTGRES_PASSWORD=CHANGEME_postgres_password
DATABASE_URL=postgresql://neuroinsight:CHANGEME_postgres_password@localhost:5432/neuroinsight
# Fallback to SQLite (single-user only, no concurrency):
# DATABASE_URL=sqlite:///./neuroinsight_research.db

# --- Redis (Celery broker + result backend) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGEME_redis_password

# --- MinIO (Object storage for inputs/outputs) ---
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGEME_minio_access_key
MINIO_SECRET_KEY=CHANGEME_minio_secret_key
MINIO_SECURE=false

# Data Directories (local filesystem, used alongside MinIO)
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
PIPELINES_DIR=./pipelines

# Pipeline Licenses (auto-detected if placed in project root)
# FreeSurfer license (free): https://surfer.nmr.mgh.harvard.edu/registration.html
# FS_LICENSE_PATH=./license.txt
# MELD Graph license (free, v2.2.4+): register at https://forms.gle/meld-graph
# MELD_LICENSE_PATH=./meld_license.txt

# Execution Backend
# Options: local (Docker), slurm (HPC)
BACKEND_TYPE=local
MAX_CONCURRENT_JOBS=4

# Celery Workers — max concurrent local Docker jobs and data transfers.
# HPC/SLURM jobs are not affected (managed by SLURM scheduler).
# Reduce to 1-2 on machines with limited RAM/CPU; the rest will queue.
CELERY_CONCURRENCY=5

# HPC Configuration (for SLURM backend)
HPC_HOST=hpc.university.edu
HPC_USER=username
HPC_SSH_PORT=22  # Use 22 for direct connection, 2222 for reverse SSH tunnel
# HPC_SSH_KEY_PATH=~/.ssh/id_rsa  # Omit to use SSH agent
HPC_WORK_DIR=/scratch/username/neuroinsight
HPC_PARTITION=general
# HPC_ACCOUNT=my_allocation
# HPC_QOS=normal
HPC_CONTAINER_RUNTIME=singularity
# HPC_MODULES=singularity/3.8,cuda/11.8
# HPC_FS_LICENSE_PATH=/path/on/hpc/to/license.txt       # FreeSurfer license ON the HPC filesystem
# HPC_MELD_LICENSE_PATH=/path/on/hpc/to/meld_license.txt # MELD license ON the HPC filesystem

# Security (must be at least 32 characters)
SECRET_KEY=CHANGEME_secret_key_at_least_32_characters_long
