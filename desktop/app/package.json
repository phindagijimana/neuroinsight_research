{
  "name": "nir-desktop-app",
  "version": "0.1.0",
  "private": true,
  "description": "NIR Desktop Electron shell",
  "homepage": "https://github.com/phindagijimana/neuroinsight_research",
  "author": {
    "name": "NeuroInsight Research Team",
    "email": "noreply@neuroinsight.local"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check src/backendManager.js && node --check src/platformAdapter.js && node --check src/desktopState.js && node --check src/preflight.js && node --check src/diagnostics.js && node --check src/licenseManager.js && node --check src/credentialStore.js && node --check src/appLock.js && node --check renderer/renderer.js",
    "pack": "electron-builder --dir",
    "dist:linux": "electron-builder --linux AppImage deb --publish never",
    "dist:linux:ci": "electron-builder --linux AppImage deb --publish never",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist:win:ci": "electron-builder --win nsis --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:mac:ci": "electron-builder --mac dmg zip --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.neuroinsight.desktop",
    "productName": "NeuroInsight Research Desktop",
    "asar": true,
    "artifactName": "nir-desktop-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "../dist",
      "buildResources": "build"
    },
    "icon": "assets/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "assets/**/*",
      "config/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "maintainer": "NeuroInsight Research Team <noreply@neuroinsight.local>",
      "category": "Science"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    }
  }
}
