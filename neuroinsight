        echo "  $0 stop                       # Stop services"
        echo "  $0 restart                    # Restart services"
        echo "  $0 status                     # Check status"
        echo "  $0 logs                       # View logs"
        echo ""
        echo "  # Force Manual Mode (skip systemd)"
        echo "  $0 start --manual             # Start without systemd"
        echo "  $0 stop --manual              # Stop manual processes"
        echo "  $0 status --manual            # Check manual status"
        echo ""
