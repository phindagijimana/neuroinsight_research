        echo "  status-systemd    - Show systemd services status"
        echo "  logs-systemd      - Follow systemd logs (use: logs-systemd [backend|worker|beat|monitor|all])"
        echo "  uninstall-systemd - Remove systemd services"
        echo ""
        echo "Other Commands:"
        echo "  reinstall         - Complete reinstallation guide"
        echo "  monitor           - Advanced monitoring options"
        echo "  nosleep           - Prevent system sleep while jobs run"
        echo "  clean             - Remove old completed/failed jobs"
        echo "  delete            - Delete a specific job by ID"
        echo "  bring             - Recover a completed job by ID"
        echo "  dev-start         - Start dev backend services"
        echo "  dev-stop          - Stop dev backend services"
        echo "  dev-status        - Show dev backend status"
        echo ""
        echo "Examples:"
        echo ""
        echo "  # Installation & Setup"
        echo "  $0 check-wsl                  # Check WSL environment (Windows/WSL users)"
        echo "  $0 install                    # Install NeuroInsight"
        echo "  $0 license                    # Setup FreeSurfer license"
        echo ""
        echo "  # Basic Usage (Auto-detects systemd)"
