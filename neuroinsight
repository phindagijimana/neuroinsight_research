#!/bin/bash
# NeuroInsight Launcher - Terminal-agnostic wrapper
# Avoids terminal corruption issues in IDE environments

# Detect if we're in a problematic terminal environment
if [[ "$TERM_PROGRAM" == "vscode" ]] || [[ "$TERM_PROGRAM" == "vscode-insiders" ]] || [[ -n "$VSCODE_PID" ]]; then
    # Special case for installation - needs regular terminal
    if [[ "$1" == "install" ]]; then
        echo "Installation requires a regular terminal (not VS Code terminal)"
        echo "Please run this command in a regular terminal:"
        echo "  ./neuroinsight install"
        exit 1
    fi

    echo "Detected VS Code terminal environment"
    echo "Using Python-based startup to avoid corruption issues..."
    echo ""

    PYTHON_BIN="python3"
else
    if [ -f "venv/bin/activate" ]; then
        PYTHON_BIN="venv/bin/python"
    else
        PYTHON_BIN="python3"
    fi
fi

# ============================================================================
# SYSTEMD AUTO-DETECTION AND MANAGEMENT
# ============================================================================

check_systemd_available() {
    # Check if systemd is available on this system
    command -v systemctl &> /dev/null
}

check_systemd_installed() {
    # Check if our systemd services are installed
    systemctl --user list-unit-files 2>/dev/null | grep -q "neuroinsight-backend.service"
}

auto_install_systemd() {
    # Automatically install systemd services (first run only)
    echo ""
    echo "=========================================="
    echo "First Run: Setting up automatic restart"
    echo "=========================================="
    echo ""
    echo "[Step 1/3] Checking systemd availability..."
    
    if ! check_systemd_available; then
        echo "  [INFO] Systemd not available on this system"
        echo "  [INFO] Using manual start method"
        return 1
    fi
    
    echo "  [OK] Systemd detected"
    echo ""
    echo "[Step 2/3] Installing systemd services..."
    echo "  Installing to ~/.config/systemd/user/"
    
    if [ -f "systemd/install_systemd.sh" ]; then
        # Run install script silently
        if ./systemd/install_systemd.sh > /tmp/neuroinsight_systemd_install.log 2>&1; then
            echo "  [OK] Services installed"
            echo "  [OK] Auto-start enabled"
            echo "  [INFO] Services will auto-restart on failure"
            echo ""
            echo "[Step 3/3] Systemd setup complete!"
            echo ""
            return 0
        else
            echo "  [WARNING] Installation failed"
            echo "  [INFO] Falling back to manual start"
            echo "  [INFO] See /tmp/neuroinsight_systemd_install.log for details"
            return 1
        fi
    else
        echo "  [WARNING] systemd/install_systemd.sh not found"
        echo "  [INFO] Using manual start method"
        return 1
    fi
}

start_docker_containers() {
    # Start Docker containers - check if they exist and start them
    if command -v docker &> /dev/null; then
        # Check for stopped containers (including all status types)
        local all_containers=$(docker ps -a -q --filter "name=neuroinsight-" 2>/dev/null || true)
        
        if [ -n "$all_containers" ]; then
            # Check which ones are stopped
            local stopped_containers=$(docker ps -a -q --filter "name=neuroinsight-" --filter "status=exited" 2>/dev/null || true)
            
            if [ -n "$stopped_containers" ]; then
                echo "  Starting stopped Docker containers..."
                docker start $stopped_containers > /dev/null 2>&1 || true
                
                # Wait for PostgreSQL to be ready
                echo "  Waiting for PostgreSQL to be ready..."
                for i in {1..15}; do
                    if docker exec neuroinsight-db pg_isready -U neuroinsight > /dev/null 2>&1; then
                        echo "  PostgreSQL is ready"
                        break
                    fi
                    sleep 1
                done
                
                echo "  Docker containers started"
            else
                # All containers are already running
                local running_count=$(docker ps -q --filter "name=neuroinsight-" 2>/dev/null | wc -l || echo "0")
                echo "  Docker containers already running ($running_count containers)"
                
                # Verify PostgreSQL is responsive
                if docker exec neuroinsight-db pg_isready -U neuroinsight > /dev/null 2>&1; then
                    echo "  PostgreSQL is responsive"
                else
                    echo "  Warning: PostgreSQL may not be ready"
                fi
            fi
            
            # Ensure data directories exist
            mkdir -p "$HOME/.local/share/neuroinsight/uploads" 2>/dev/null || true
            mkdir -p "$HOME/.local/share/neuroinsight/results" 2>/dev/null || true
            mkdir -p "$HOME/.local/share/neuroinsight/outputs" 2>/dev/null || true
            
            # Check if database schema is initialized
            if [ -f "backend/alembic.ini" ]; then
                # Quick check: try to query the database
                local schema_ok=false
                if docker exec neuroinsight-db psql -U neuroinsight -d neuroinsight -c "SELECT 1 FROM jobs LIMIT 1" > /dev/null 2>&1; then
                    schema_ok=true
                fi
                
                if [ "$schema_ok" = false ]; then
                    echo "  Initializing database schema..."
                    if [ -f "venv/bin/activate" ]; then
                        (source venv/bin/activate && export PYTHONPATH="$PWD:$PYTHONPATH" && alembic -c backend/alembic.ini upgrade head > /dev/null 2>&1 && echo "  Database schema initialized") || echo "  Warning: Database initialization may have failed"
                    fi
                fi
            fi
        else
            echo "  No Docker containers found"
            echo "  Infrastructure containers will be created automatically"
        fi
    else
        echo "  Docker not available"
    fi
}

use_systemd_start() {
    # Start services using systemd
    local force_install="$1"
    
    if ! check_systemd_available; then
        return 1
    fi
    
    # Check if services are installed
    if ! check_systemd_installed; then
        if [ "$force_install" = "auto" ]; then
            # Auto-install on first run
            if ! auto_install_systemd; then
                return 1
            fi
        else
            echo "[INFO] Systemd services not installed"
            echo "[INFO] Run './neuroinsight install-systemd' to enable automatic restart"
            return 1
        fi
    fi
    
    # Services are installed, use them
    echo "=========================================="
    echo "Starting NeuroInsight (systemd)"
    echo "=========================================="
    echo ""
    
    # Start Docker containers first
    echo "[1/5] Starting Docker containers..."
    start_docker_containers
    sleep 2
    echo ""
    
    # Start services in order
    echo "[2/5] Starting backend..."
    systemctl --user start neuroinsight-backend
    sleep 2
    
    echo "[3/5] Starting worker..."
    systemctl --user start neuroinsight-worker
    sleep 1
    
    echo "[4/5] Starting beat scheduler..."
    systemctl --user start neuroinsight-beat
    sleep 1
    
    echo "[5/5] Starting job monitor..."
    systemctl --user start neuroinsight-monitor
    
    echo ""
    echo "=========================================="
    echo "NeuroInsight started with systemd!"
    echo "=========================================="
    echo ""
    echo "Services will auto-restart on failure"
    echo "Web Interface: http://localhost:8000"
    echo ""
    echo "Management commands:"
    echo "  ./neuroinsight status     # Check status"
    echo "  ./neuroinsight stop       # Stop services"
    echo "  ./neuroinsight restart    # Restart services"
    echo "  ./neuroinsight logs       # View logs"
    echo ""
    
    return 0
}

stop_docker_containers() {
    # Smart Docker management - stop infrastructure, cleanup job containers
    if ! command -v docker &> /dev/null; then
        echo "  Docker not available"
        return
    fi
    
    local stopped_count=0
    local cleaned_count=0
    
    # 1. Stop running NeuroInsight infrastructure containers (but don't remove them)
    # Check if infrastructure containers are running
    local infra_running=$(docker ps --format "{{.Names}}" | grep -E "^neuroinsight-(postgres|redis|minio)$" | tr '\n' ' ')
    
    if [ -n "$infra_running" ]; then
        echo "  Stopping infrastructure containers (postgres, redis, minio)..."
        docker stop $infra_running > /dev/null 2>&1 || true
        stopped_count=$((stopped_count + $(echo "$infra_running" | wc -w)))
    fi
    
    # 2. Stop and remove FreeSurfer job containers (these are temporary)
    local freesurfer_running=$(docker ps -q --filter "name=freesurfer-job-" 2>/dev/null)
    if [ -n "$freesurfer_running" ]; then
        echo "  Stopping FreeSurfer job containers..."
        docker stop $freesurfer_running > /dev/null 2>&1 || true
        docker rm $freesurfer_running > /dev/null 2>&1 || true
        stopped_count=$((stopped_count + $(echo "$freesurfer_running" | wc -w)))
        cleaned_count=$((cleaned_count + $(echo "$freesurfer_running" | wc -w)))
    fi
    
    # 3. Remove exited FreeSurfer job containers (cleanup old jobs)
    local exited_freesurfer=$(docker ps -aq --filter "name=freesurfer-job-" --filter "status=exited" 2>/dev/null)
    if [ -n "$exited_freesurfer" ]; then
        echo "  Cleaning up exited FreeSurfer containers..."
        docker rm $exited_freesurfer > /dev/null 2>&1 || true
        cleaned_count=$((cleaned_count + $(echo "$exited_freesurfer" | wc -w)))
    fi
    
    # 4. Stop Docker event monitoring service (if running)
    if systemctl is-active --quiet neuroinsight-docker-events.service 2>/dev/null; then
        echo "  Stopping Docker event monitor service..."
        # This is a system service, requires sudo
        if command -v sudo &> /dev/null; then
            sudo systemctl stop neuroinsight-docker-events.service 2>/dev/null || true
        fi
    elif systemctl --user is-active --quiet neuroinsight-docker-events.service 2>/dev/null; then
        echo "  Stopping Docker event monitor service..."
        systemctl --user stop neuroinsight-docker-events.service 2>/dev/null || true
    fi
    
    # Summary
    if [ $stopped_count -gt 0 ] || [ $cleaned_count -gt 0 ]; then
        echo "  Stopped: $stopped_count containers, Cleaned: $cleaned_count job containers"
    else
        echo "  No Docker containers to stop or clean"
    fi
}

use_systemd_stop() {
    if check_systemd_available && check_systemd_installed; then
        echo "Stopping NeuroInsight services..."
        echo ""
        echo "[1/3] Stopping systemd services..."
        systemctl --user stop neuroinsight-monitor 2>/dev/null || true
        systemctl --user stop neuroinsight-beat 2>/dev/null || true
        systemctl --user stop neuroinsight-worker 2>/dev/null || true
        systemctl --user stop neuroinsight-backend 2>/dev/null || true
        echo "  Systemd services stopped"
        echo ""
        echo "[2/3] Cleaning up orphaned Python processes..."
        # Kill any remaining neuroinsight Python processes (orphaned or from manual runs)
        ORPHANED=$(ps aux | grep -E "python.*(backend|worker|celery|uvicorn|job_monitor)" | grep neuroinsight | grep -v grep | awk '{print $2}')
        if [ -n "$ORPHANED" ]; then
            echo "$ORPHANED" | xargs kill -9 2>/dev/null || true
            ORPHANED_COUNT=$(echo "$ORPHANED" | wc -l)
            echo "  Cleaned up $ORPHANED_COUNT orphaned process(es)"
        else
            echo "  No orphaned processes found"
        fi
        echo ""
        echo "[3/3] Stopping Docker containers..."
        stop_docker_containers
        echo ""
        echo "All NeuroInsight services stopped!"
        return 0
    fi
    return 1
}

use_systemd_restart() {
    if check_systemd_available && check_systemd_installed; then
        echo "Restarting NeuroInsight services (systemd)..."
        systemctl --user restart neuroinsight-backend
        systemctl --user restart neuroinsight-worker
        systemctl --user restart neuroinsight-beat
        systemctl --user restart neuroinsight-monitor
        echo "Services restarted!"
        return 0
    fi
    return 1
}

use_systemd_status() {
    if check_systemd_available && check_systemd_installed; then
        echo "NeuroInsight Systemd Services Status"
        echo "===================================="
        echo ""
        
        echo "Backend:"
        systemctl --user status neuroinsight-backend --no-pager -l | head -10
        echo ""
        
        echo "Worker:"
        systemctl --user status neuroinsight-worker --no-pager -l | head -10
        echo ""
        
        echo "Beat Scheduler:"
        systemctl --user status neuroinsight-beat --no-pager -l | head -10
        echo ""
        
        echo "Job Monitor:"
        systemctl --user status neuroinsight-monitor --no-pager -l | head -10
        echo ""
        
        echo "Summary:"
        systemctl --user list-units "neuroinsight-*" --no-pager
        return 0
    fi
    return 1
}

# Use Python-based scripts for consistency
case "$1" in
    start)
        # Check for --manual flag to force manual start
        if [[ "$2" == "--manual" ]]; then
            echo "Starting NeuroInsight (manual mode)..."
            exec "$PYTHON_BIN" scripts/start.py
        fi
        
        # Try systemd first (auto-install if needed)
        if use_systemd_start "auto"; then
            exit 0
        fi
        
        # Fall back to manual start
        echo "Starting NeuroInsight (manual mode)..."
        exec "$PYTHON_BIN" scripts/start.py
        ;;
    dev-start)
        echo "Starting NeuroInsight (dev backend)..."
        exec "$PYTHON_BIN" scripts/start_dev.py
        ;;
    stop)
        # Check for --manual flag to force manual stop
        if [[ "$2" == "--manual" ]]; then
            echo "Stopping NeuroInsight (manual mode)..."
            "$PYTHON_BIN" scripts/nosleep.py stop >/dev/null 2>&1 || true
            "$PYTHON_BIN" scripts/stop.py "${@:2}"
            # Stop Docker containers
            echo "Stopping Docker containers..."
            stop_docker_containers
            exit 0
        fi
        
        # Try systemd first
        if use_systemd_stop; then
            exit 0
        fi
        
        # Fall back to manual stop
        echo "Stopping NeuroInsight (manual mode)..."
        "$PYTHON_BIN" scripts/nosleep.py stop >/dev/null 2>&1 || true
        "$PYTHON_BIN" scripts/stop.py "${@:2}"
        # Stop Docker containers
        echo "Stopping Docker containers..."
        stop_docker_containers
        exit 0
        ;;
    dev-stop)
        echo "Stopping NeuroInsight (dev backend)..."
        exec "$PYTHON_BIN" scripts/stop_dev.py "${@:2}"
        ;;
    status)
        # Check for --manual flag to force manual status
        if [[ "$2" == "--manual" ]]; then
            echo "NeuroInsight Status (manual mode)..."
            exec ./scripts/status.sh
        fi
        
        # Try systemd first
        if use_systemd_status; then
            exit 0
        fi
        
        # Fall back to manual status
        echo "NeuroInsight Status (manual mode)..."
        exec ./scripts/status.sh
        ;;
    dev-status)
        echo "NeuroInsight Dev Status..."
        exec ./scripts/status_dev.sh
        ;;
    restart)
        # Check for --manual flag to force manual restart
        if [[ "$2" == "--manual" ]]; then
            echo "Restarting NeuroInsight (manual mode)..."
            "$PYTHON_BIN" scripts/stop.py
            sleep 2
            exec "$PYTHON_BIN" scripts/start.py
        fi
        
        # Try systemd first
        if use_systemd_restart; then
            exit 0
        fi
        
        # Fall back to manual restart
        echo "Restarting NeuroInsight (manual mode)..."
        "$PYTHON_BIN" scripts/stop.py
        sleep 2
        exec "$PYTHON_BIN" scripts/start.py
        ;;
    logs)
        shift
        exec "$PYTHON_BIN" scripts/logs.py "$@"
        ;;
    monitor)
        echo "NeuroInsight Monitoring..."
        exec ./scripts/monitor.sh "${@:2}"
        ;;
    nosleep)
        echo "NeuroInsight No-Sleep..."
        exec "$PYTHON_BIN" scripts/nosleep.py start
        ;;
    clean)
        echo "NeuroInsight Cleanup..."
        exec "$PYTHON_BIN" scripts/clean.py "${@:2}"
        ;;
    delete)
        echo "NeuroInsight Job Deletion..."
        exec "$PYTHON_BIN" scripts/delete_job.py "${@:2}"
        ;;
    bring)
        echo "NeuroInsight Job Recovery..."
        exec "$PYTHON_BIN" scripts/bring_job.py "${@:2}"
        ;;
    health)
        echo "[HEALTH] NeuroInsight System Health Check"
        echo "=========================================="

            # Check system resources
            echo "[HEALTH] System Resources:"
            echo "  Memory: $(free -h | awk 'NR==2{printf "%.1fGB used / %.1fGB total (%.0f%%)", $3/1024, $2/1024, $3*100/$2}')"
            echo "  Disk: $(df -h / | awk 'NR==2{print $3 " used / " $2 " total (" $5 " used)"}')"
            echo "  Load: $(uptime | awk -F'load average:' '{print $2}' | sed 's/^ *//')"

            # Check Docker services
            echo ""
            echo "[HEALTH] Docker Services:"
            if command -v docker &> /dev/null; then
                containers=$(docker ps --filter "name=neuroinsight" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}")
                if [ -n "$containers" ]; then
                    echo "$containers"
                else
                    echo "  No NeuroInsight containers running"
                    echo "  [ACTION] Run './neuroinsight start' to start services"
                fi
            else
                echo "  Docker not available"
            fi

            # Check web interface
            echo ""
            echo "[HEALTH] Web Interface:"
            if curl -s -f http://localhost:8000/health >/dev/null 2>&1; then
                echo "  [OK] Backend API responding"
            else
                echo "  [FAIL] Backend API not responding"
                echo "  [ACTION] Check if services are running with './neuroinsight status'"
            fi

            # Overall assessment
            echo ""
            echo "[HEALTH] Overall Status:"
            healthy_containers=$(docker ps -q --filter "name=neuroinsight" 2>/dev/null | wc -l)
            if [ "$healthy_containers" -ge 3 ] && curl -s -f http://localhost:8000/health >/dev/null 2>&1; then
                echo "  [OK] SYSTEM HEALTHY - All services operational"
            else
                echo "  [WARN] ISSUES DETECTED - Some services may be down"
                echo "  [ACTION] Run './neuroinsight start' to restart services"
            fi
        ;;
    license)
        echo "FreeSurfer License Management"
        if [ -f "license.txt" ]; then
            echo "License file found: license.txt"
            # Basic validation - check if it has content
            if [ $(wc -l < license.txt) -ge 4 ] && ! grep -q "REPLACE THIS EXAMPLE CONTENT" license.txt 2>/dev/null; then
                echo "License appears to be valid"
                echo ""
                echo "To update license:"
                echo "1. Replace license.txt with new license file"
                echo "2. Restart NeuroInsight: ./neuroinsight stop && ./neuroinsight start"
            else
                echo "Warning: License file exists but may contain example content"
                echo ""
                echo "To fix:"
                echo "1. Visit: https://surfer.nmr.mgh.harvard.edu/registration.html"
                echo "2. Download the real license.txt file"
                echo "3. Replace the current license.txt file"
            fi
        else
            echo "No license file found"
            echo ""
            echo "To set up FreeSurfer license:"
            echo "1. Visit: https://surfer.nmr.mgh.harvard.edu/registration.html"
            echo "2. Register with your research email"
            echo "3. Download the license.txt file"
            echo "4. Place license.txt in this directory (same folder as NeuroInsight)"
            echo "5. Restart NeuroInsight: ./neuroinsight stop && ./neuroinsight start"
            echo ""
            echo "Note: Without license, NeuroInsight will use mock processing for demonstrations"
        fi
        ;;
    check-wsl)
        echo "Running WSL Environment Check..."
        if [ -f "scripts/check_wsl.sh" ]; then
            exec ./scripts/check_wsl.sh
        else
            echo "Error: check_wsl.sh not found in scripts/ directory"
            echo "Please ensure you're in the NeuroInsight project directory"
            exit 1
        fi
        ;;
    reinstall)
        echo "[REINSTALL] NeuroInsight Complete Reinstallation Guide"
        echo ""
        echo "This will completely remove NeuroInsight and allow a fresh installation."
        echo ""

            # Automated cleanup section
            echo "[CLEANUP] AUTOMATED CLEANUP (Running now...):"
            echo ""

            # Stop any running NeuroInsight services first
            echo "1. [STOP] Stopping any running NeuroInsight services..."
            if command -v docker &> /dev/null; then
                # Stop containers if they exist
                if docker ps -q --filter "name=neuroinsight" | grep -q .; then
                    echo "   Stopping running containers..."
                    docker stop $(docker ps -q --filter "name=neuroinsight") 2>/dev/null || true
                fi

                # Remove containers if they exist
                if docker ps -a -q --filter "name=neuroinsight" | grep -q .; then
                    echo "   Removing containers..."
                    docker rm $(docker ps -a -q --filter "name=neuroinsight") 2>/dev/null || true
                fi

                # Clean up volumes (optional, ask user)
                echo "   [TIP] Run 'docker volume prune' manually if you want to remove old data volumes"
                echo "   [TIP] Run 'docker system prune' for complete Docker cleanup"
            else
                echo "   Docker not available - skipping container cleanup"
            fi

            # Clean up any local files that might conflict
            echo "2. [CLEAN] Cleaning up local NeuroInsight files..."
            # Remove any lingering PID files, logs, or databases
            rm -f *.pid *.log neuroinsight*.db 2>/dev/null || true
            rm -rf __pycache__/ 2>/dev/null || true

            echo ""
            echo "[SUCCESS] Automated cleanup completed!"
            echo ""

            # Manual steps
            echo "[MANUAL] MANUAL STEPS (Complete these now):"
            echo ""
            echo "3. [DIR] Navigate to the parent directory (where neuroinsight_local is located):"
            echo "   cd .."
            echo ""
            echo "4. [REMOVE] Remove the entire NeuroInsight directory:"
            echo "   rm -rf neuroinsight_local/"
            echo ""
            echo "5. [CLONE] Re-clone the repository:"
            echo "   git clone https://github.com/phindagijimana/neuroinsight_local.git"
            echo "   cd neuroinsight_local"
            echo ""
            echo "6. [INSTALL] Run fresh installation:"
            echo "   ./neuroinsight install"
            echo ""
            echo "7. [LICENSE] Set up FreeSurfer license:"
            echo "   ./neuroinsight license"
            echo ""
            echo "8. [START] Start NeuroInsight:"
            echo "   ./neuroinsight start"
            echo ""
            echo "[WARNING] WARNING: This will delete ALL data, jobs, and configurations!"
            echo "   Make sure to backup any important data before proceeding."
            echo ""
            echo "[TIP] Automated cleanup handled containers and temporary files."
            echo "[TIP] This is useful if you encounter persistent issues or want a completely clean setup."
        ;;
    install)
        echo "NeuroInsight Installation"
        if [ -f "scripts/install.sh" ]; then
            echo "Running installation script..."
            exec ./scripts/install.sh
        else
            echo "Error: install.sh not found in scripts/ directory"
            echo "Please ensure you're in the NeuroInsight project directory"
            exit 1
        fi
        ;;
    install-systemd)
        echo "Installing NeuroInsight systemd services..."
        if [ -f "systemd/install_systemd.sh" ]; then
            exec ./systemd/install_systemd.sh
        else
            echo "Error: systemd/install_systemd.sh not found"
            echo "Please ensure you're in the NeuroInsight project directory"
            exit 1
        fi
        ;;
    uninstall-systemd)
        echo "Uninstalling NeuroInsight systemd services..."
        if [ -f "systemd/uninstall_systemd.sh" ]; then
            exec ./systemd/uninstall_systemd.sh
        else
            echo "Error: systemd/uninstall_systemd.sh not found"
            exit 1
        fi
        ;;
    start-systemd)
        echo "Starting NeuroInsight services via systemd..."
        echo ""
        
        # Check if services are installed
        if ! systemctl --user list-unit-files | grep -q "neuroinsight-backend.service"; then
            echo "ERROR: Systemd services not installed!"
            echo "Run: ./neuroinsight install-systemd"
            exit 1
        fi
        
        # Start services in order
        echo "Starting backend..."
        systemctl --user start neuroinsight-backend
        sleep 2
        
        echo "Starting worker..."
        systemctl --user start neuroinsight-worker
        sleep 1
        
        echo "Starting beat scheduler..."
        systemctl --user start neuroinsight-beat
        sleep 1
        
        echo "Starting job monitor..."
        systemctl --user start neuroinsight-monitor
        
        echo ""
        echo "Services started! Check status with:"
        echo "  ./neuroinsight status-systemd"
        ;;
    stop-systemd)
        echo "Stopping NeuroInsight services via systemd..."
        systemctl --user stop neuroinsight-monitor 2>/dev/null || true
        systemctl --user stop neuroinsight-beat 2>/dev/null || true
        systemctl --user stop neuroinsight-worker 2>/dev/null || true
        systemctl --user stop neuroinsight-backend 2>/dev/null || true
        echo "Systemd services stopped!"
        echo "Stopping Docker containers..."
        stop_docker_containers
        echo "All services stopped!"
        ;;
    restart-systemd)
        echo "Restarting NeuroInsight services via systemd..."
        systemctl --user restart neuroinsight-backend
        systemctl --user restart neuroinsight-worker
        systemctl --user restart neuroinsight-beat
        systemctl --user restart neuroinsight-monitor
        echo "Services restarted!"
        ;;
    status-systemd)
        echo "NeuroInsight Systemd Services Status"
        echo "===================================="
        echo ""
        
        # Check if services are installed
        if ! systemctl --user list-unit-files | grep -q "neuroinsight-backend.service"; then
            echo "WARNING: Systemd services not installed"
            echo ""
            echo "To install: ./neuroinsight install-systemd"
            exit 0
        fi
        
        # Show status of each service
        echo "Backend:"
        systemctl --user status neuroinsight-backend --no-pager -l | head -15
        echo ""
        
        echo "Worker:"
        systemctl --user status neuroinsight-worker --no-pager -l | head -15
        echo ""
        
        echo "Beat Scheduler:"
        systemctl --user status neuroinsight-beat --no-pager -l | head -15
        echo ""
        
        echo "Job Monitor:"
        systemctl --user status neuroinsight-monitor --no-pager -l | head -15
        echo ""
        
        echo "Summary:"
        systemctl --user list-units "neuroinsight-*" --no-pager
        ;;
    logs-systemd)
        # Follow logs for specified service or all
        service="${2:-all}"
        if [ "$service" = "all" ]; then
            echo "Following all NeuroInsight logs (Ctrl+C to stop)..."
            journalctl --user -u neuroinsight-* -f
        else
            echo "Following $service logs (Ctrl+C to stop)..."
            journalctl --user -u "neuroinsight-$service" -f
        fi
        ;;
