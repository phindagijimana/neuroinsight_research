#!/bin/bash
# NeuroInsight Docker Management CLI
# Equivalent to ./neuroinsight but for Docker deployment

set -e

CONTAINER_NAME="neuroinsight"
IMAGE_NAME="phindagijimana321/neuroinsight:latest"
VOLUME_NAME="neuroinsight-data"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if Docker is installed
check_docker() {
    if ! command -v docker &> /dev/null; then
        log_error "Docker is not installed."
        echo "Please install Docker first:"
        echo "  https://docs.docker.com/get-docker/"
        exit 1
    fi
}

# Check if container exists
container_exists() {
    docker ps -a --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"
}

# Check if container is running
container_running() {
    docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"
}

# Check if a port is available
port_available() {
    local port=$1
    ! (lsof -i:${port} -sTCP:LISTEN -t >/dev/null 2>&1 || netstat -tln 2>/dev/null | grep -q ":${port} ")
}

# Find available port in range 8000-8050
find_available_port() {
    for port in {8000..8050}; do
        if port_available $port; then
            echo $port
            return 0
        fi
    done
    return 1
}

# Get the port the container is using
get_container_port() {
    if container_exists; then
        docker port ${CONTAINER_NAME} 8000 2>/dev/null | cut -d':' -f2
    fi
}

# Start container
cmd_start() {
    check_docker
    
    if container_running; then
        log_warning "NeuroInsight container is already running"
        local port=$(get_container_port)
        if [ -n "$port" ]; then
            echo "Web Interface: http://localhost:${port}"
        fi
        cmd_status
        return 0
    fi
    
    if container_exists; then
        log_info "Starting existing container..."
        docker start ${CONTAINER_NAME}
        sleep 5
        log_success "Container started"
        
        local port=$(get_container_port)
        if [ -n "$port" ]; then
            echo ""
            log_success "NeuroInsight is ready!"
            echo "Web Interface: http://localhost:${port}"
        fi
    else
        log_error "Container does not exist. Please run: ./neuroinsight-docker install"
        exit 1
    fi
    
    echo ""
    cmd_status
}

# Stop container
cmd_stop() {
    check_docker
    
    if ! container_running; then
        log_warning "Container is not running"
        return 0
    fi
    
    log_info "Stopping NeuroInsight container..."
    docker stop ${CONTAINER_NAME}
    log_success "Container stopped"
}

# Restart container
cmd_restart() {
    cmd_stop
    sleep 2
    cmd_start
}

# Show status
cmd_status() {
    check_docker
    
    echo "======================================"
    echo "NeuroInsight Docker Status"
    echo "======================================"
    echo ""
    
    if ! container_exists; then
        log_error "Container does not exist"
        echo "Run: ./neuroinsight-docker install"
        return 1
    fi
    
    if container_running; then
        log_success "Container is running"
        echo ""
        
        # Get the port
        local port=$(get_container_port)
        if [ -n "$port" ]; then
            echo "Web Interface: http://localhost:${port}"
            echo ""
        fi
        
        # Show container info
        docker ps --filter name=${CONTAINER_NAME} --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
        echo ""
        
        # Show service status inside container
        log_info "Service status:"
        docker exec ${CONTAINER_NAME} supervisorctl status 2>/dev/null || log_warning "Could not get service status"
        
    else
        log_warning "Container exists but is not running"
        echo "Run: ./neuroinsight-docker start"
    fi
}

# Health check
cmd_health() {
    check_docker
    
    if ! container_running; then
        log_error "Container is not running"
        return 1
    fi
    
    echo "Running health check..."
    docker exec ${CONTAINER_NAME} /app/healthcheck.sh
}

# View logs
cmd_logs() {
    check_docker
    
    if ! container_running; then
        log_error "Container is not running"
        return 1
    fi
    
    local service="${1:-all}"
    
    case $service in
        backend|worker|beat|monitor|postgresql|redis|minio)
            log_info "Showing $service logs (Ctrl+C to exit)..."
            docker exec ${CONTAINER_NAME} tail -f /var/log/supervisor/${service}.log 2>/dev/null || \
            docker exec ${CONTAINER_NAME} tail -f /var/log/supervisor/${service}_err.log
            ;;
        container)
            log_info "Showing container logs (Ctrl+C to exit)..."
            docker logs -f ${CONTAINER_NAME}
            ;;
        all|*)
            log_info "Showing all logs (Ctrl+C to exit)..."
            docker logs -f ${CONTAINER_NAME}
            ;;
    esac
}

# Install/run container
cmd_install() {
    check_docker
    
    if container_exists; then
        log_warning "Container already exists"
        read -p "Remove and recreate? (y/n): " confirm
        if [ "$confirm" != "y" ]; then
            exit 0
        fi
        cmd_remove
    fi
    
    log_info "Installing NeuroInsight..."
    
    # Find available port
    log_info "Finding available port (range: 8000-8050)..."
    local port=$(find_available_port)
    
    if [ -z "$port" ]; then
        log_error "No available ports found in range 8000-8050"
        log_error "Please stop other services or free up a port in this range"
        exit 1
    fi
    
    log_success "Selected port: $port"
    
    # Calculate MinIO ports based on selected port
    local minio_api_port=$((port + 1000))
    local minio_console_port=$((port + 1001))
    
    # Check for license in multiple locations (like native deployment)
    local license_mount=""
    local license_path=""
    
    # Check current directory first (deploy/)
    if [ -f "./license.txt" ]; then
        license_path="$(pwd)/license.txt"
        log_success "Found license.txt in current directory"
    # Check parent directory (neuroinsight_local/)
    elif [ -f "../license.txt" ]; then
        license_path="$(cd .. && pwd)/license.txt"
        log_success "Found license.txt in neuroinsight_local directory"
    # Check src directory (one level up from neuroinsight_local)
    elif [ -f "../../license.txt" ]; then
        license_path="$(cd ../.. && pwd)/license.txt"
        log_success "Found license.txt in src directory"
    # Check home directory
    elif [ -f "$HOME/license.txt" ]; then
        license_path="$HOME/license.txt"
        log_success "Found license.txt in home directory"
    fi
    
    if [ -n "$license_path" ]; then
        # Verify it's not an example file
        if grep -q "REPLACE THIS EXAMPLE CONTENT" "$license_path" 2>/dev/null || \
           grep -q "FreeSurfer License File - EXAMPLE" "$license_path" 2>/dev/null; then
            log_warning "License file appears to be example content"
            log_warning "Please replace with real FreeSurfer license"
            log_warning "Visit: https://surfer.nmr.mgh.harvard.edu/registration.html"
        else
            license_mount="-v ${license_path}:/app/license.txt:ro"
            log_success "License validated and will be mounted"
        fi
    else
        log_warning "FreeSurfer license not found (will run in demo mode)"
        log_info "To enable full FreeSurfer processing:"
        log_info "  1. Get license: https://surfer.nmr.mgh.harvard.edu/registration.html"
        log_info "  2. Save as license.txt in this directory"
        log_info "  3. Run: ./neuroinsight-docker restart"
    fi
    
    log_info "Creating container..."
    log_info "  Web Interface: http://localhost:${port}"
    log_info "  MinIO API: http://localhost:${minio_api_port}"
    log_info "  MinIO Console: http://localhost:${minio_console_port}"
    
    log_info "Docker permissions will be auto-configured at container startup"
    log_info "This ensures compatibility with Linux, WSL2, and Docker Desktop"
    log_info "Host paths will be auto-detected from volume mounts"
    
    docker run -d \
        --name ${CONTAINER_NAME} \
        -p ${port}:8000 \
        -p ${minio_api_port}:9000 \
        -p ${minio_console_port}:9001 \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v ${VOLUME_NAME}:/data \
        ${license_mount} \
        --restart unless-stopped \
        ${IMAGE_NAME}
    
    # Note: Container entrypoint automatically detects and configures Docker socket permissions
    
    log_success "Container created"
    log_info "Waiting for services to start (30 seconds)..."
    sleep 30
    
    cmd_status
    echo ""
    log_success "NeuroInsight is ready!"
    echo ""
    local actual_port=$(get_container_port)
    echo "Web Interface: http://localhost:${actual_port}"
    echo "MinIO API: http://localhost:${minio_api_port}"
    echo "MinIO Console: http://localhost:${minio_console_port}"
}

# Remove container
cmd_remove() {
    check_docker
    
    if container_running; then
        log_info "Stopping container..."
        docker stop ${CONTAINER_NAME}
    fi
    
    if container_exists; then
        log_info "Removing container..."
        docker rm ${CONTAINER_NAME}
        log_success "Container removed"
    else
        log_warning "Container does not exist"
    fi
}

# Clean data
cmd_clean() {
    check_docker
    
    local days=30
    
    # Parse --days option
    while [[ $# -gt 0 ]]; do
        case $1 in
            --days)
                days="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done
    
    log_warning "This will clean up jobs older than ${days} days"
    read -p "Continue? (y/n): " confirm
    if [ "$confirm" != "y" ]; then
        exit 0
    fi
    
    if container_running; then
        log_info "Running cleanup (retaining last ${days} days)..."
        docker exec ${CONTAINER_NAME} bash -c "
            export DATABASE_URL='postgresql://neuroinsight:neuroinsight_secure_password@localhost:5432/neuroinsight'
            cd /app && PYTHONPATH=/app python3 scripts/clean.py --days ${days}
        "
        log_success "Cleanup completed"
    else
        log_error "Container is not running"
    fi
}

# Delete specific job
cmd_delete() {
    check_docker
    
    local job_id="$1"
    local force="${2}"
    
    if [ -z "$job_id" ]; then
        log_error "Please specify job ID"
        echo "Usage: ./neuroinsight-docker delete <job_id> [--force]"
        echo ""
        echo "Example: ./neuroinsight-docker delete d1a2c36e"
        echo "         ./neuroinsight-docker delete d1a2c36e --force"
        exit 1
    fi
    
    if ! container_running; then
        log_error "Container is not running"
        return 1
    fi
    
    log_info "Deleting job: ${job_id}"
    
    # Build command with optional force flag
    local cmd="cd /app && PYTHONPATH=/app python3 scripts/delete_job.py ${job_id}"
    if [ "$force" = "--force" ] || [ "$force" = "-f" ]; then
        cmd="${cmd} --force"
    fi
    
    docker exec -it ${CONTAINER_NAME} bash -c "$cmd"
}

# Bring/recover job
cmd_bring() {
    check_docker
    
    local job_id="$1"
    
    if [ -z "$job_id" ]; then
        log_error "Please specify job ID"
        echo "Usage: ./neuroinsight-docker bring <job_id>"
        echo ""
        echo "Example: ./neuroinsight-docker bring abc12345"
        exit 1
    fi
    
    if ! container_running; then
        log_error "Container is not running"
        return 1
    fi
    
    log_info "Recovering job: ${job_id}"
    docker exec ${CONTAINER_NAME} bash -c "cd /app && PYTHONPATH=/app python3 scripts/bring_job.py ${job_id}"
}

# Access shell
cmd_shell() {
    check_docker
    
    if ! container_running; then
        log_error "Container is not running"
        return 1
    fi
    
    local user="${1:-neuroinsight}"
    log_info "Opening shell as $user (type 'exit' to quit)..."
    docker exec -it -u ${user} ${CONTAINER_NAME} bash
}

# Update image
cmd_update() {
    check_docker
    
    log_info "Pulling latest image..."
    docker pull ${IMAGE_NAME}
    
    log_info "Recreating container with new image..."
    cmd_remove
    cmd_install
}

# Backup data
cmd_backup() {
    check_docker
    
    local backup_file="neuroinsight-backup-$(date +%Y%m%d-%H%M%S).tar.gz"
    
    log_info "Creating backup..."
    docker run --rm \
        -v ${VOLUME_NAME}:/data \
        -v $(pwd):/backup \
        alpine tar czf /backup/${backup_file} /data
    
    log_success "Backup created: ${backup_file}"
}

# Restore data
cmd_restore() {
    check_docker
    
    local backup_file="$1"
    
    if [ -z "$backup_file" ]; then
        log_error "Please specify backup file"
        echo "Usage: ./neuroinsight-docker restore <backup-file>"
        exit 1
    fi
    
    if [ ! -f "$backup_file" ]; then
        log_error "Backup file not found: $backup_file"
        exit 1
    fi
    
    log_warning "This will replace all current data"
    read -p "Continue? (y/n): " confirm
    if [ "$confirm" != "y" ]; then
        exit 0
    fi
    
    log_info "Restoring from backup..."
    docker run --rm \
        -v ${VOLUME_NAME}:/data \
        -v $(pwd):/backup \
        alpine sh -c "rm -rf /data/* && tar xzf /backup/${backup_file}"
    
    log_success "Restore completed"
    log_info "Restart container: ./neuroinsight-docker restart"
}

# Check license status
cmd_license() {
    echo "======================================"
    echo "FreeSurfer License Check"
    echo "======================================"
    echo ""
    
    # Check if container is running
    if container_running; then
        log_info "Checking license in container..."
        if docker exec ${CONTAINER_NAME} test -f /app/license.txt; then
            log_success "License file found in container"
            
            # Check if it's example content
            if docker exec ${CONTAINER_NAME} grep -q "REPLACE THIS EXAMPLE CONTENT" /app/license.txt 2>/dev/null || \
               docker exec ${CONTAINER_NAME} grep -q "FreeSurfer License File - EXAMPLE" /app/license.txt 2>/dev/null; then
                log_warning "License appears to be example content"
                echo ""
                echo "Please replace with a real FreeSurfer license:"
                echo "  1. Visit: https://surfer.nmr.mgh.harvard.edu/registration.html"
                echo "  2. Register (free for research)"
                echo "  3. Save license as license.txt in this directory"
                echo "  4. Restart: ./neuroinsight-docker restart"
            else
                # Show first line (email)
                local first_line=$(docker exec ${CONTAINER_NAME} head -n1 /app/license.txt)
                log_success "Valid license detected"
                echo "  Email: $first_line"
                echo ""
                log_success "FreeSurfer processing is enabled!"
            fi
        else
            log_warning "No license file found in container"
            echo ""
            echo "Application is running in demo mode (mock processing)"
            echo ""
            echo "To enable full FreeSurfer processing:"
            echo "  1. Get license: https://surfer.nmr.mgh.harvard.edu/registration.html"
            echo "  2. Save as license.txt in this directory"
            echo "  3. Restart: ./neuroinsight-docker restart"
        fi
    else
        # Check on host system
        log_info "Checking for license files on host..."
        echo ""
        
        local found=false
        
        if [ -f "./license.txt" ]; then
            log_success "Found: ./license.txt"
            found=true
        fi
        
        if [ -f "../neuroinsight_local/license.txt" ]; then
            log_success "Found: ../neuroinsight_local/license.txt"
            found=true
        fi
        
        if [ -f "$HOME/license.txt" ]; then
            log_success "Found: $HOME/license.txt"
            found=true
        fi
        
        if [ "$found" = false ]; then
            log_warning "No license file found"
            echo ""
            echo "To enable FreeSurfer processing:"
            echo "  1. Visit: https://surfer.nmr.mgh.harvard.edu/registration.html"
            echo "  2. Register (free for research)"
            echo "  3. Save license as license.txt in this directory"
            echo "  4. Install/Start container"
        else
            echo ""
            log_info "License will be automatically mounted when container starts"
        fi
    fi
}

# Show help
cmd_help() {
    cat << 'EOF'
NeuroInsight Docker Management CLI

Usage: ./neuroinsight-docker <command> [options]

Container Management:
  install           - Install/create NeuroInsight container (auto-selects port 8000-8050)
  start             - Start the container
  stop              - Stop the container
  restart           - Restart the container
  remove            - Remove the container
  update            - Update to latest image and recreate

Status & Monitoring:
  status            - Show container and service status
  health            - Run health check
  license           - Check FreeSurfer license status
  logs [service]    - View logs (backend|worker|beat|monitor|all|container)
  shell [user]      - Access container shell (default: neuroinsight)

Maintenance:
  clean [--days N]  - Clean up old jobs (default: 30 days)
  delete <job_id>   - Delete a specific job by ID
  bring <job_id>    - Recover a completed job by ID
  backup            - Create backup of data volume
  restore <file>    - Restore from backup file

Examples:
  ./neuroinsight-docker install          # Install and start (auto-detects license)
  ./neuroinsight-docker status           # Check status and port
  ./neuroinsight-docker license          # Check FreeSurfer license
  ./neuroinsight-docker logs backend     # View backend logs
  ./neuroinsight-docker clean --days 90  # Clean jobs older than 90 days
  ./neuroinsight-docker delete d1a2c36e  # Delete specific job
  ./neuroinsight-docker bring abc12345   # Recover job by ID
  ./neuroinsight-docker shell            # Access shell
  ./neuroinsight-docker backup           # Create backup
  ./neuroinsight-docker update           # Update to latest

Quick Start:
  1. Build image:        ./build.sh
  2. Install:            ./neuroinsight-docker install
  3. Check status:       ./neuroinsight-docker status
  4. Access web UI:      Check status output for URL

Port Selection:
  - Automatically finds available port in range 8000-8050
  - Default: 8000 (if available)
  - No manual port configuration required

License Detection:
  - Automatically detects license.txt in multiple locations:
    * Current directory (./license.txt)
    * Parent directory (../neuroinsight_local/license.txt)
    * Home directory (~/license.txt)
  - Auto-mounts when container starts
  - Check status: ./neuroinsight-docker license

Container: ${CONTAINER_NAME}
Image: ${IMAGE_NAME}
Volume: ${VOLUME_NAME}

For Docker Compose: docker-compose up -d

EOF
}

# Main command dispatcher
case "${1:-help}" in
    install)
        cmd_install
        ;;
    start)
        cmd_start
        ;;
    stop)
        cmd_stop
        ;;
    restart)
        cmd_restart
        ;;
    status)
        cmd_status
        ;;
    health)
        cmd_health
        ;;
    logs)
        cmd_logs "$2"
        ;;
    shell)
        cmd_shell "$2"
        ;;
    clean)
        shift
        cmd_clean "$@"
        ;;
    delete)
        cmd_delete "$2" "$3"
        ;;
    bring)
        cmd_bring "$2"
        ;;
    remove|uninstall)
        cmd_remove
        ;;
    update)
        cmd_update
        ;;
    backup)
        cmd_backup
        ;;
    restore)
        cmd_restore "$2"
        ;;
    license)
        cmd_license
        ;;
    help|--help|-h)
        cmd_help
        ;;
    *)
        log_error "Unknown command: $1"
        echo ""
        cmd_help
        exit 1
        ;;
esac
